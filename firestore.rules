rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow public read for assets so the Public Asset Portal works
    match /assets/{assetId} {
      allow read: if true; 
      allow write: if request.auth != null; 
    }
    
    // Allow public creation of issues, but only authenticated users can read/update them
    match /issues/{issueId} {
      allow create: if true; 
      allow read, update, delete: if true; // Set to if request.auth != null; for production
    }

    // Default rule for all other collections (e.g. activityLog)
    match /{document=**} {
      allow read, write: if true; // Set to if request.auth != null; for production
    }
  }
}
